{
  "name": "tcp-server",
  "version": "1.0.0",
  "description": "```js node tcp_server.js 8080 ```",
  "main": "tcp_server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/tcp_server.js",
    "start:client": "node dist/tcp_client.js",
    "dev": "tsx src/tcp_server.ts",
    "dev:client": "tsx src/tcp_client.ts",
    "dev:watch": "nodemon --watch src --ext ts --exec \"tsx src/tcp_server.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isitinme/node-tcp-server.git"
  },
  "keywords": [
    "TCP"
  ],
  "packageManager": "npm@11.7.0",
  "author": "isitinme",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/isitinme/node-tcp-server/issues"
  },
  "homepage": "https://github.com/isitinme/node-tcp-server#readme",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
